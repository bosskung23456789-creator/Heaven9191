local function getAllTools()
    local tools = {}
 
    for _,v in pairs(P.Backpack:GetChildren()) do
        if v:IsA("Tool") then
            table.insert(tools, v.Name)
        end
    end
 
    if P.Character then
        for _,v in pairs(P.Character:GetChildren()) do
            if v:IsA("Tool") then
                table.insert(tools, v.Name)
            end
        end
    end
 
    table.sort(tools)
    return tools
