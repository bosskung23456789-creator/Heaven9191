-- =========================
-- CHECK TARGET IN RANGE
-- =========================

local function isTargetInRange()
    local char = P.Character
    if not char then return false end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end

    for _,obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= char then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            local part = obj:FindFirstChild("HumanoidRootPart")
            
            if humanoid and humanoid.Health > 0 and part then
                local distance = (root.Position - part.Position).Magnitude
                if distance <= attackDistance then
                    return true
                end
            end
        end
    end
    
    return false
end
 
-- =========================
-- USE TOOL
-- =========================
 
local function useSelectedTool()
    if not selectedToolName then return end
    if not isTargetInRange() then return end -- ✅ เช็คระยะก่อนตี
    
    local char = P.Character
    if not char then return end
 
    local tool = char:FindFirstChild(selectedToolName)
 
    if not tool then
        local bpTool = P.Backpack:FindFirstChild(selectedToolName)
        if bpTool then
            bpTool.Parent = char
            tool = bpTool
        end
    end
 
    if tool then
        tool:Activate()
    end
end
 
