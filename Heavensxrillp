local ToolTab = Window:Tab({
    Title = "Auto Tool",
})
 
local autoTool = false
local selectedToolName = nil
local toolDelay = 0.3
local attackDistance = 30 -- ✅ ระยะโจมตี
 
-- =========================
-- GET TOOL LIST
-- =========================
 
local function getAllTools()
    local tools = {}
 
    for _,v in pairs(P.Backpack:GetChildren()) do
        if v:IsA("Tool") then
            table.insert(tools, v.Name)
        end
    end
 
    if P.Character then
        for _,v in pairs(P.Character:GetChildren()) do
            if v:IsA("Tool") then
                table.insert(tools, v.Name)
            end
        end
    end
 
    table.sort(tools)
    return tools
end

-- =========================
-- CHECK TARGET IN RANGE
-- =========================

local function isTargetInRange()
    local char = P.Character
    if not char then return false end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end

    for _,obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= char then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            local part = obj:FindFirstChild("HumanoidRootPart")
            
            if humanoid and humanoid.Health > 0 and part then
                local distance = (root.Position - part.Position).Magnitude
                if distance <= attackDistance then
                    return true
                end
            end
        end
    end
    
    return false
end
 
-- =========================
-- USE TOOL
-- =========================
 
local function useSelectedTool()
    if not selectedToolName then return end
    if not isTargetInRange() then return end -- ✅ เช็คระยะก่อนตี
    
    local char = P.Character
    if not char then return end
 
    local tool = char:FindFirstChild(selectedToolName)
 
    if not tool then
        local bpTool = P.Backpack:FindFirstChild(selectedToolName)
        if bpTool then
            bpTool.Parent = char
            tool = bpTool
        end
    end
 
    if tool then
        tool:Activate()
    end
end
 
-- =========================
-- LOOP
-- =========================
 
task.spawn(function()
    while true do
        if autoTool then
            useSelectedTool()
            task.wait(toolDelay)
        else
            task.wait(0.1)
        end
    end
end)
 
