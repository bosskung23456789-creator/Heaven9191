-- 🔥 ตัดทุกตัวที่มีคำว่า goku ในชื่อ
local function isGoku(model)
if not model then return true end
local name = string.lower(model.Name)
return string.find(name, "goku") ~= nil
end
 
local function getAllBosses()
local folder = getBossFolder()
if not folder then return {} end
 
local bosses = {}  
for _,v in pairs(folder:GetChildren()) do  
    if v:IsA("Model") and not isGoku(v) then  
        table.insert(bosses, v)  
    end  
end  
return bosses
 
end
 
local function getRoot(model)
return model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
end
 
local function getHumanoid(model)
return model:FindFirstChildOfClass("Humanoid")
end
 
local function warpBehindAndLook(target)
if isGoku(target) then return end -- 🔥 กันอีกชั้น
 
local char = P.Character  
if not char then return end  
 
local hrp = char:FindFirstChild("HumanoidRootPart")  
if not hrp then return end  
 
local root = getRoot(target)  
if not root then return end  
 
local behindCF = root.CFrame * CFrame.new(0,0,-4)  
hrp.CFrame = CFrame.lookAt(behindCF.Position, root.Position)
 
end
 
local function attack(target)
if isGoku(target) then return end -- 🔥 กันอีกชั้น
 
local char = P.Character  
if not char then return end  
 
for _,tool in pairs(char:GetChildren()) do  
    if tool:IsA("Tool") then  
        tool:Activate()  
    end  
end
 
end
 
