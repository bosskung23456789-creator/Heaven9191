local function WarpToIsland(displayName)

    local MapFolder = workspace:FindFirstChild("Map")
    if not MapFolder then
        warn("Map ยังไม่โหลด")
        return
    end

    local targetPart = nil

    -- 🔥 Starter (Map 5 Model Union)
    if displayName == "Starter Island" then
        local map5 = MapFolder:FindFirstChild("5")
        if map5 and map5:FindFirstChild("Model") then
            targetPart = getSafePart(map5.Model:FindFirstChild("Union"))
        end
    end

    -- 🔥 ระบบปกติ
    if not targetPart then
        local realName = WarpList[displayName]
        local island = MapFolder:FindFirstChild(realName)
        targetPart = getSafePart(island)
    end

    if not targetPart then
        warn("ไม่พบจุดวาร์ป:", displayName)
        return
    end

    game.Players.LocalPlayer.Character:WaitForChild("HumanoidRootPart").CFrame =
        targetPart.CFrame + Vector3.new(0,5,0)
end

