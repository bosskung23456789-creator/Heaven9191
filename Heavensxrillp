-- หา Get itemNPC ที่ยังอยู่
local function findItemNPC()
    for _,v in pairs(workspace:GetDescendants()) do
        if string.find(v.Name, "Get itemNPC") then
            return v
        end
    end
    return nil
end

-- วาร์ปไปด้านหน้า NPC
local function warpInFront(target, distance)
    local part = getSafePart(target)
    if not part then return end

    local hrp = player.Character:WaitForChild("HumanoidRootPart")

    distance = distance or 5

    -- ด้านหน้าของ NPC
    local frontPosition = part.CFrame * CFrame.new(0, 0, -distance)

    hrp.CFrame = frontPosition
end

-- ระบบหลัก
local autoSystem = false

task.spawn(function()
    while true do
        task.wait(1)

        if autoSystem then

            local itemNPC = findItemNPC()

            if itemNPC then
                -- ยังมี itemNPC → วาร์ปไปหา
                warpInFront(itemNPC, 5)
            else
                -- itemNPC หาย → กลับร้าน
                local shop = workspace:FindFirstChild("Mod")
                if shop and shop:FindFirstChild("NPC Shop") then
                    local thunder = shop["NPC Shop"]:FindFirstChild("ThunderNPC")
                    if thunder then
                        warpInFront(thunder, 6)
                    end
                end
            end

        end
    end
end)

