-- 🔥 กรองชื่อที่ไม่ต้องการ
local function isBadName(name)
    local lower = string.lower(name)

    local blacklist = {
        "npc","quest","joan","xxtaksoxx","boss",
        "tribe","teleport","stat reset","save spawn",
        "rank","haki","god jeed","charaterrig"
    }

    for _,word in ipairs(blacklist) do
        if string.find(lower, word) then
            return true
        end
    end

    return false
end

-- 🔍 ดึงรายชื่อมอนจาก workspace.Mod
local function getMonsterList()
    local list = {}

    local mod = workspace:FindFirstChild("Mod")
    if not mod then return list end

    for _,v in pairs(mod:GetDescendants()) do
        if v:IsA("Model") and not isBadName(v.Name) then
            local hum = v:FindFirstChildOfClass("Humanoid")
            if hum then
                table.insert(list, v.Name)
            end
        end
    end

    table.sort(list)

    -- กันชื่อซ้ำ
    local unique = {}
    local final = {}
    for _,name in ipairs(list) do
        if not unique[name] then
            unique[name] = true
            table.insert(final, name)
        end
    end

    return final
end
